{
	"compilerOptions": {
		"strict": true,
		"strictPropertyInitialization": false,
		"outDir": "dist",
		"allowJs": true,
		"checkJs": true,
		"target": "es2022",
		"module": "es2022",
		"moduleResolution": "bundler",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"paths": {
			"#/*": ["./src/*"]
		},
		"skipLibCheck": true
	}
}
